# LLM Configuration
# Choose your LLM model (e.g., gpt-3.5-turbo, gpt-4, llama2, mistral)
LLM_MODEL=gpt-3.5-turbo

# OpenAI API Key (required for OpenAI models)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Base URL (optional, defaults to http://localhost:11434/v1 for Ollama)
# For OpenAI: https://api.openai.com/v1
# For local Ollama: http://localhost:11434/v1
OPENAI_BASE_URL=http://localhost:11434/v1

# Database Configuration (optional, defaults are in config/dev.exs)
# DATABASE_URL=ecto://postgres:postgres@localhost/chat_controller_dev
